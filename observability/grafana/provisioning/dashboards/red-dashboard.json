{
  "annotations": { "list": [] },
  "editable": true,
  "schemaVersion": 39,
  "title": "otel-observability — RED",
  "tags": ["red", "otel"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "panels": [
    {
      "type": "timeseries",
      "title": "Rate — requisições/s por rota",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum by (route) (rate(http_requests_total[1m]))",
          "legendFormat": "{{route}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Errors — % de respostas 4xx/5xx",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{status=~\"[45]..\"}[1m])) / clamp_min(sum(rate(http_requests_total[1m])), 1)",
          "legendFormat": "erro",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Duration — latência p95 (ms)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95",
          "refId": "A"
        }
      ]
    }
  ]
}
